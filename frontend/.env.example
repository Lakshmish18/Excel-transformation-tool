# Frontend environment (copy to .env in frontend directory)

# Backend API base URL - include /api/v1 (no trailing slash)
# Local dev: leave unset to use Vite proxy (/api/v1 -> localhost:8000)
# Production: set to your Railway backend URL, e.g. https://your-app.up.railway.app/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Supabase (optional; app works with localStorage fallback if unset)
# Get from: https://app.supabase.com -> Project -> Settings -> API
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
