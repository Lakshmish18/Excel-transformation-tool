# Backend environment (copy to .env in backend directory)

# Max file upload size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# CORS allowed origins (comma-separated)
# Production: add your Vercel frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Port (Railway sets PORT automatically)
PORT=8000

# Supabase (optional; for cloud features)
# SUPABASE_URL=your-supabase-url
# SUPABASE_KEY=your-supabase-key
