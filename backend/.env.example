# Backend environment (copy to .env in backend directory)

# Max file upload size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# CORS allowed origins (comma-separated)
# Production: add your Vercel frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI (required for AI Assistant). Use a single line — no line breaks inside the key.
# OPENAI_API_KEY=sk-...

# Port (Railway sets PORT automatically)
PORT=8000

# Supabase (optional; cloud features + required on Vercel for shared uploads)
# Create a Storage bucket named "excel-uploads" (private is fine).
# SUPABASE_URL=https://xxxx.supabase.co
# Use the service role key only on the server (never in frontend).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
